// Esquema de Base de Datos - Servicio Técnico
// Prisma Schema para PostgreSQL

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================
// MODELO DE ÓRDENES DE SERVICIO
// =============================================

model Order {
  id                     String   @id @default(cuid())
  orderNumber           String   @unique @map("order_number")
  customerId            Int?     @map("customer_id")

  // Información del Cliente
  nombre                String
  telefono              String
  email                 String
  direccion             String
  ciudad                String

  // Información del Electrodoméstico
  tipoElectrodomestico  String   @map("tipo_electrodomestico")
  marca                 String?
  modelo                String?
  año                   Int?     @map("anio")

  // Información del Servicio
  tipoServicio          String   @map("tipo_servicio")
  descripcionProblema   String?  @map("descripcion_problema")
  urgencia              String   // 'baja', 'media', 'alta'

  // Programación
  fechaPreferida        DateTime? @map("fecha_preferida")
  horario               String?
  comentarios           String?

  // Control del Sistema
  estado                String   @default("pendiente") // Estados definidos en constantes
  prioridad             Int      @default(1) // 1=baja, 2=media, 3=alta
  costoEstimado         Decimal? @map("costo_estimado") @db.Decimal(10,2)
  costoFinal            Decimal? @map("costo_final") @db.Decimal(10,2)

  // Timestamps
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  fechaCompletado       DateTime? @map("fecha_completado")

  // Relaciones
  assignments           Assignment[]
  history               OrderHistory[]
  notifications         Notification[]
  customer              Customer?         @relation(fields: [customerId], references: [id])
  invoices              Invoice[]
  messages              Message[]

  // Índices
  @@index([estado])
  @@index([createdAt])
  @@index([email])
  @@index([tipoElectrodomestico])
  @@index([customerId])
  @@map("orders")
}

// =============================================
// MODELO DE TÉCNICOS
// =============================================

model Technician {
  id                    Int      @id @default(autoincrement())
  nombre                String
  telefono              String   @unique
  email                 String   @unique
  cedula                String   @unique

  // Especialidades y Ubicación
  especialidades        Json     // Array de especialidades: ["nevera", "lavadora"]
  zonaTrabajoArea       String?  @map("zona_trabajo")
  activo                Boolean  @default(true)
  disponible            Boolean  @default(true)
  estadoActual          String   @default("disponible") @map("estado_actual") // disponible, ocupado, en_descanso, offline

  // Métricas de Rendimiento
  ordenesCompletadas    Int      @default(0) @map("ordenes_completadas")
  calificacionPromedio  Decimal  @default(5.00) @map("calificacion_promedio") @db.Decimal(3,2)
  tiempoPromedioServicio Int?    @map("tiempo_promedio_servicio") // en minutos

  // Información Adicional
  fechaIngreso          DateTime @default(now()) @map("fecha_ingreso")
  ultimaActividad       DateTime @default(now()) @map("ultima_actividad")

  // Aceptación de Términos y Condiciones
  termsAcceptedAt       DateTime? @map("terms_accepted_at")
  termsVersion          String?   @map("terms_version")

  // Timestamps
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relaciones
  assignments           Assignment[]

  // Índices
  @@index([activo])
  @@index([disponible])
  @@index([zonaTrabajoArea])
  @@map("technicians")
}

// =============================================
// MODELO DE ASIGNACIONES
// =============================================

model Assignment {
  id                    Int       @id @default(autoincrement())
  orderId               String    @map("order_id")
  technicianId          Int       @map("technician_id")

  // Programación
  fechaAsignacion       DateTime  @default(now()) @map("fecha_asignacion")
  fechaProgramada       DateTime? @map("fecha_programada")
  fechaInicio           DateTime? @map("fecha_inicio")
  fechaCompletada       DateTime? @map("fecha_completada")

  // Notas y Seguimiento
  notasAsignacion       String?   @map("notas_asignacion")
  notasTecnico          String?   @map("notas_tecnico")
  tiempoEstimado        Int?      @map("tiempo_estimado") // minutos
  tiempoReal            Int?      @map("tiempo_real") // minutos

  // Estado de la Asignación
  estado                String    @default("asignado") // asignado, en_camino, en_proceso, completado
  razonCancelacion      String?   @map("razon_cancelacion")

  // Costos
  costoManoObra         Decimal?  @map("costo_mano_obra") @db.Decimal(10,2)
  costoRepuestos        Decimal?  @map("costo_repuestos") @db.Decimal(10,2)

  // Timestamps
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relaciones
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  technician            Technician @relation(fields: [technicianId], references: [id])

  // Índices
  @@index([orderId])
  @@index([technicianId])
  @@index([fechaProgramada])
  @@index([estado])
  @@map("assignments")
}

// =============================================
// MODELO DE HISTORIAL DE ÓRDENES
// =============================================

model OrderHistory {
  id              Int      @id @default(autoincrement())
  orderId         String   @map("order_id")

  // Cambio de Estado
  estadoAnterior  String?  @map("estado_anterior")
  estadoNuevo     String   @map("estado_nuevo")

  // Información del Cambio
  changedBy       String   @map("changed_by") // 'system', 'admin', 'technician'
  changedById     String?  @map("changed_by_id") // ID del usuario que hizo el cambio
  notas           String?
  razon           String?  // Razón del cambio

  // Datos Adicionales
  metadata        Json?    // Información adicional en formato JSON

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")

  // Relaciones
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Índices
  @@index([orderId])
  @@index([createdAt])
  @@index([changedBy])
  @@map("order_history")
}

// =============================================
// MODELO DE CLIENTES
// =============================================

model Customer {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  nombre       String
  apellido     String?
  telefono     String
  direccion    String?
  ciudad       String?
  activo       Boolean   @default(true)
  isOnboarded  Boolean   @default(false) @map("is_onboarded") // Control de onboarding
  preferencias Json?
  lastLogin    DateTime? @map("last_login")

  // Aceptación de Términos y Condiciones
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  termsVersion    String?   @map("terms_version")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orders                Order[]
  passwordResetTokens   PasswordResetToken[]

  @@map("customers")
}

// =============================================
// MODELO DE NOTIFICACIONES
// =============================================

model Notification {
  id              Int       @id @default(autoincrement())
  orderId         String?   @map("order_id")

  // Identificación del Usuario (In-App)
  userId          String    @map("user_id") // ID del usuario destinatario (String para soportar CUIDs o IDs)
  userType        String    @map("user_type") // 'admin', 'customer', 'technician'
  read            Boolean   @default(false)

  // Información de la Notificación
  tipo            String    // 'email', 'sms', 'push', 'system', 'assignment'
  canal           String    @default("system") // canal usado: 'system' para in-app
  destinatario    String    // email o identificador
  asunto          String?
  mensaje         String
  metadata        Json?     // Datos adicionales para navegación { link: '/orders/123' }
  plantilla       String?

  // Estado del Envío
  enviado         Boolean   @default(false)
  fechaEnvio      DateTime? @map("fecha_envio")
  entregado       Boolean   @default(false)
  fechaEntrega    DateTime? @map("fecha_entrega")

  // Manejo de Errores
  intentos        Int       @default(0)
  maxIntentos     Int       @default(3) @map("max_intentos")
  errorMensaje    String?   @map("error_mensaje")
  ultimoError     DateTime? @map("ultimo_error")

  // Programación
  programadaPara  DateTime? @map("programada_para")
  prioridad       Int       @default(1)

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relaciones
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Índices
  @@index([userId, userType])
  @@index([read])
  @@index([orderId])
  @@index([tipo])
  @@index([enviado])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================
// MODELO DE USUARIOS ADMINISTRADORES
// =============================================

model AdminUser {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  email           String    @unique
  passwordHash    String    @map("password_hash")

  // Información Personal
  nombre          String
  apellido        String?
  telefono        String?

  // Roles y Permisos
  role            String    @default("admin") // 'super_admin', 'admin', 'viewer', 'technician_manager'
  permisos        Json?     // Permisos específicos en formato JSON
  activo          Boolean   @default(true)

  // Información de Sesión
  lastLogin       DateTime? @map("last_login")
  loginAttempts   Int       @default(0) @map("login_attempts")
  accountLocked   Boolean   @default(false) @map("account_locked")
  lockUntil       DateTime? @map("lock_until")

  // Configuraciones Personales
  preferencias    Json?     // Configuraciones de UI, notificaciones, etc.
  zona            String?   // Zona horaria preferida
  idioma          String    @default("es") // Idioma de la interfaz

  // Aceptación de Términos y Condiciones
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  termsVersion    String?   @map("terms_version")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  passwordResetTokens PasswordResetToken[]

  // Índices
  @@index([username])
  @@index([email])
  @@index([role])
  @@index([activo])
  @@map("admin_users")
}

// =============================================
// MODELO DE CONFIGURACIONES DEL SISTEMA
// =============================================

model SystemSetting {
  id              Int       @id @default(autoincrement())
  key             String    @unique
  value           String

  // Metadatos
  descripcion     String?
  tipo            String    @default("string") // 'string', 'number', 'boolean', 'json'
  categoria       String?   // 'email', 'sms', 'system', 'ui'
  esPublico       Boolean   @default(false) @map("es_publico") // Si es visible en frontend

  // Control de Cambios
  updatedBy       String?   @map("updated_by") // username del admin que actualizó
  validationRule  String?   @map("validation_rule") // Regla de validación

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Índices
  @@index([categoria])
  @@index([esPublico])
  @@map("system_settings")
}

// =============================================
// MODELO DE TIPOS DE SERVICIOS
// =============================================

model ServiceType {
  id              Int       @id @default(autoincrement())
  nombre          String    @unique
  descripcion     String?

  // Configuración
  activo          Boolean   @default(true)
  icono           String?   // Nombre del icono a usar
  color           String?   // Color hex para UI
  orden           Int       @default(0) // Para ordenamiento

  // Costos
  costoBase       Decimal?  @map("costo_base") @db.Decimal(10,2)
  tiempoEstimado  Int?      @map("tiempo_estimado") // en minutos

  // Especialidades Requeridas
  especialidadesRequeridas Json? @map("especialidades_requeridas")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Índices
  @@index([activo])
  @@index([orden])
  @@map("service_types")
}

// =============================================
// MODELO DE ZONAS DE TRABAJO
// =============================================

model WorkZone {
  id              Int       @id @default(autoincrement())
  nombre          String    @unique
  descripcion     String?

  // Configuración Geográfica
  coordenadas     Json?     // Polígono de la zona en formato GeoJSON
  cobertura       String?   // Descripción textual de la cobertura

  // Configuración de Servicio
  activo          Boolean   @default(true)
  costoAdicional  Decimal?  @map("costo_adicional") @db.Decimal(10,2)
  tiempoAdicional Int?      @map("tiempo_adicional") // minutos adicionales

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Índices
  @@index([activo])
  @@map("work_zones")
}

// =============================================
// MODELO DE FACTURAS ELECTRÓNICAS
// =============================================

model Invoice {
  id                String   @id @default(cuid())
  invoiceNumber     String   @unique @map("invoice_number") // Ej: FAC-2024-01-0001
  orderId           String   @map("order_id")

  // Información del Cliente
  clientName        String   @map("client_name")
  clientEmail       String   @map("client_email")
  clientPhone       String   @map("client_phone")
  clientAddress     String   @map("client_address")
  clientCity        String   @map("client_city")
  clientDocument    String?  @map("client_document") // NIT o Cédula

  // Detalles del Servicio
  serviceType       String   @map("service_type")
  serviceDescription String  @map("service_description")
  applianceType     String   @map("appliance_type")

  // Costos
  subtotal          Decimal  @db.Decimal(10,2)
  iva               Decimal  @db.Decimal(10,2) // 19% en Colombia
  total             Decimal  @db.Decimal(10,2)

  // Desglose de Costos
  laborCost         Decimal? @map("labor_cost") @db.Decimal(10,2)
  partsCost         Decimal? @map("parts_cost") @db.Decimal(10,2)
  transportCost     Decimal? @map("transport_cost") @db.Decimal(10,2)

  // Método de Pago
  paymentMethod     String   @map("payment_method") // efectivo, transferencia, nequi, daviplata
  paymentStatus     String   @default("pending") @map("payment_status") // pending, paid, cancelled
  paymentDate       DateTime? @map("payment_date")
  paymentReference  String?  @map("payment_reference") // Número de transacción

  // Archivos
  pdfUrl            String?  @map("pdf_url") // URL del PDF generado
  pdfPath           String?  @map("pdf_path") // Ruta local del PDF

  // Estado de Envío
  emailSent         Boolean  @default(false) @map("email_sent")
  emailSentAt       DateTime? @map("email_sent_at")
  whatsappSent      Boolean  @default(false) @map("whatsapp_sent")
  whatsappSentAt    DateTime? @map("whatsapp_sent_at")

  // Información Fiscal
  fiscalYear        Int      @map("fiscal_year")
  fiscalMonth       Int      @map("fiscal_month")

  // Notas
  notes             String?
  internalNotes     String?  @map("internal_notes")

  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relaciones
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Índices
  @@index([orderId])
  @@index([invoiceNumber])
  @@index([clientEmail])
  @@index([fiscalYear, fiscalMonth])
  @@index([paymentStatus])
  @@map("invoices")
}

// =============================================
// MODELO DE SOLICITUDES DE TÉCNICOS
// =============================================

model TechnicianApplication {
  id                    String   @id @default(cuid())

  // Datos Personales
  nombre                String
  apellido              String
  cedula                String   @unique
  email                 String   @unique
  telefono              String
  direccion             String
  ciudad                String

  // Datos Profesionales
  especialidades        Json     // ["nevera", "lavadora", "aire_acondicionado"]
  zonaPreferida         String   @map("zona_preferida")
  experienciaAnios      Int?     @map("experiencia_anios")
  documentosUrl         String?  @map("documentos_url") // Ruta del PDF con cédula y certificados

  // Estado de la Solicitud
  estado                String   @default("pendiente") // pendiente, aprobado, rechazado
  motivoRechazo         String?  @map("motivo_rechazo")

  // Revisión
  revisadoPor           Int?     @map("revisado_por") // ID del admin que revisó
  fechaRevision         DateTime? @map("fecha_revision")
  notasAdmin            String?  @map("notas_admin")

  // Timestamps
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Índices
  @@index([estado])
  @@index([createdAt])
  @@index([email])
  @@index([cedula])
  @@map("technician_applications")
}


// =============================================
// MODELO DE MENSAJERÍA INTERNA
// =============================================

model Message {
  id              String    @id @default(cuid())

  // Relación con Orden (Opcional)
  orderId         String?   @map("order_id")
  order           Order?    @relation(fields: [orderId], references: [id])

  // Remitente
  senderId        String    @map("sender_id") // ID del usuario que envía
  senderType      String    @map("sender_type") // 'admin', 'customer', 'technician'
  senderName      String    @map("sender_name") // Para caché y mostrar rápido

  // Destinatario
  receiverId      String    @map("receiver_id") // ID del usuario que recibe
  receiverType    String    @map("receiver_type") // 'admin', 'customer', 'technician'

  // Contenido
  subject         String?
  content         String    @db.Text

  // Metadatos
  category        String    @default("general") // 'service', 'support', 'billing', 'general'
  priority        String    @default("normal") // 'low', 'normal', 'high'
  read            Boolean   @default(false)
  readAt          DateTime? @map("read_at")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Índices para búsquedas rápidas
  @@index([senderId, senderType])
  @@index([receiverId, receiverType])
  @@index([orderId])
  @@index([read])
  @@index([createdAt])
  @@map("messages")
}

// =============================================
// MODELO DE TOKENS DE RECUPERACIÓN DE CONTRASEÑA
// =============================================

model PasswordResetToken {
  id              String    @id @default(uuid())
  token           String    @unique @default(uuid())

  // Usuario asociado (puede ser Admin o Customer)
  userEmail       String    @map("user_email")
  userType        String    @map("user_type") // 'admin' o 'customer'

  // Para relaciones opcionales con AdminUser o Customer
  adminUserId     Int?      @map("admin_user_id")
  customerId      Int?      @map("customer_id")

  // Control de expiración y uso
  expiresAt       DateTime  @map("expires_at")
  used            Boolean   @default(false)
  usedAt          DateTime? @map("used_at")

  // Metadatos de seguridad
  ipAddress       String?   @map("ip_address") // IP desde donde se solicitó
  userAgent       String?   @map("user_agent") // Navegador/dispositivo

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relaciones
  adminUser       AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  customer        Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Índices para búsquedas rápidas
  @@index([token])
  @@index([userEmail])
  @@index([expiresAt])
  @@index([used])
  @@index([createdAt])
  @@map("password_reset_tokens")
}

// =============================================
// MODELO DE SECUENCIAS DE NÚMEROS DE ORDEN
// =============================================
// Garantiza generación atómica de orderNumbers sin race conditions

model OrderSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  // Timestamps
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("order_sequences")
}

// =============================================
// MODELO DE SOLICITUDES IDEMPOTENTES
// =============================================
// Previene procesamiento duplicado de requests con mismo idempotency key

model IdempotentRequest {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  response   Json
  statusCode Int      @map("status_code")
  expiresAt  DateTime @map("expires_at")

  // Timestamps
  createdAt  DateTime @default(now()) @map("created_at")

  // Índices
  @@index([expiresAt])
  @@index([createdAt])
  @@map("idempotent_requests")
}
