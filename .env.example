# 🔐 SomosTécnicos - Configuración de Entorno SEGURA (Ejemplo)
# ===============================================
# ⚠️  NUNCA COMMITEAR ESTE ARCHIVO CON VALORES REALES
# Copiar como .env y configurar valores de producción

# ====================================
# 🗄️ BASE DE DATOS (Neon Tech - PostgreSQL)
# ====================================

# Opción 1: Desarrollo Local (Docker)
DATABASE_URL="postgresql://admin:password123@localhost:5432/servicio_tecnico"

# Opción 2: Producción (Neon Tech con Connection Pooling)
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-XXXXX-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-XXXXX.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ====================================
# 🔑 AUTENTICACIÓN
# ====================================
# Generar claves seguras: `openssl rand -base64 32`
JWT_SECRET="cambiar_por_clave_segura_base64_32_bytes"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="cambiar_por_otra_clave_segura_base64_32_bytes"
NEXTAUTH_URL="http://localhost:3000"

# ==============================================
# 📧 EMAIL (Brevo / Sendinblue)
# ==============================================
# Obtener API Key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY="xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXXXXX"
BREVO_SENDER_EMAIL="noreply@somostecnicos.com"
BREVO_SENDER_NAME="SomosTécnicos"

# ==============================================
# 🚀 APP CONFIG
# ==============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT="3000"

# ==============================================
# 🧪 CREDENCIALES DEMO (Solo Desarrollo)
# ==============================================
DEMO_ADMIN_PASSWORD="Demo2026!Secure"
DEMO_TECH_PASSWORD="Demo2026!Secure"
DEMO_CLIENT_PASSWORD="Demo2026!Secure"
