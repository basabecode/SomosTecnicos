# 🔐 TecnoCity - Configuración de Entorno SEGURA
# ===============================================
# ⚠️  NUNCA COMMITEAR ESTE ARCHIVO CON VALORES REALES
# Copiar como .env y configurar valores de producción

# ====================================
# 🗄️ BASE DE DATOS - VARIABLES SEPARADAS
# ====================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=servicio_tecnico
DB_USER=admin
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_MIN_16_CARACTERES
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# 🚀 NEON DATABASE OPTIMIZADA PARA FASE 2 (Reemplazar arriba en producción):
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-XXXXX-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connection_limit=20&pool_timeout=20&statement_timeout=30000"
# 
# Parámetros de optimización:
# - connection_limit=20: Máximo 20 conexiones concurrentes por instancia
# - pool_timeout=20: Timeout de 20 segundos para obtener conexión del pool  
# - statement_timeout=30000: Timeout de 30s para queries (previene queries colgados)
# - Usa siempre el endpoint con "-pooler" para mejor performance

# ====================================
# 🔑 AUTENTICACIÓN - CLAVES ROBUSTAS
# ====================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=GENERAR_CLAVE_32_BYTES_BASE64_AQUI
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=GENERAR_OTRA_CLAVE_32_BYTES_BASE64_AQUI
NEXTAUTH_URL=http://localhost:3000

# ==============================================
# 📧 CONFIGURACIÓN DE EMAIL (Brevo)
# ==============================================
# Brevo (anteriormente Sendinblue) para emails transaccionales
# Obtén tu API key en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXXXXX
BREVO_SENDER_EMAIL=noreply@somostecnicos.com
BREVO_SENDER_NAME=SomosTécnicos
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================
# CONFIGURACIÓN DE ADMIN POR DEFECTO
# ==============================================
DEFAULT_ADMIN_EMAIL=admin@somostecnicos.com
DEFAULT_ADMIN_PASSWORD=cambiar-en-produccion
DEFAULT_ADMIN_NAME=Administrador

# ==============================================
# 🧪 CONFIGURACIÓN DE TESTING / DEMO
# ==============================================
# Estas contraseñas se usarán para los scripts de seed
DEMO_ADMIN_PASSWORD=Demo2026!Secure
DEMO_TECH_PASSWORD=Demo2026!Secure
DEMO_CLIENT_PASSWORD=Demo2026!Secure

# ==============================================
# CONFIGURACIÓN OPCIONAL
# ==============================================
REDIS_URL=redis://localhost:6379
NODE_ENV=development
PORT=3000
