# 🔐 SomosTécnicos - Configuración de Entorno SEGURA (Ejemplo)
# ===============================================
# ⚠️  NUNCA COMMITEAR ESTE ARCHIVO CON VALORES REALES
# Copiar como .env y configurar valores de producción

# ====================================
# 🗄️ BASE DE DATOS (Neon Tech - PostgreSQL)
# ====================================

# Opción 1: Desarrollo Local (Docker)
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>"

# Opción 2: Producción (Neon Tech con Connection Pooling)
# DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<NEON_POOLER_HOST>/<DB_NAME>?sslmode=require&channel_binding=require"
# DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<NEON_DIRECT_HOST>/<DB_NAME>?sslmode=require&channel_binding=require"

# ====================================
# 🔑 AUTENTICACIÓN
# ====================================
# Generar claves seguras: `openssl rand -base64 32`
JWT_SECRET="cambiar_por_clave_segura_base64_32_bytes"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="cambiar_por_otra_clave_segura_base64_32_bytes"
NEXTAUTH_URL="http://localhost:3000"

# ==============================================
# 📧 EMAIL (Brevo / Sendinblue)
# ==============================================
# Obtener API Key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY="xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXXXXX"
BREVO_SENDER_EMAIL="noreply@somostecnicos.com"
BREVO_SENDER_NAME="SomosTécnicos"

# ==============================================
# 🚀 APP CONFIG
# ==============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT="3000"

# ==============================================
# 📬 UPSTASH QSTASH — Cola de trabajos durable
# ==============================================
# Requerido en producción (Vercel) para que emails/notificaciones
# no se pierdan cuando la función serverless termina.
# Obtener en: https://console.upstash.com → QStash → Dashboard
#
# Sin estas variables, el sistema usa cola en memoria (solo válido en desarrollo).
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="eyJVc2VySUQiOiJYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWA=="
QSTASH_CURRENT_SIGNING_KEY="sig_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
QSTASH_NEXT_SIGNING_KEY="sig_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ==============================================
# 🧪 CUENTAS DE PRUEBA (Solo Desarrollo Local)
# ==============================================
# Definir correos y contraseñas propias para las cuentas de seed.
# Nunca compartir estos valores ni commitear el .env con valores reales.
DEMO_ADMIN_EMAIL="<correo_admin_local>"
DEMO_ADMIN_PASSWORD="<contraseña_admin_local>"
DEMO_TECHNICIAN_EMAIL="<correo_tecnico_local>"
DEMO_TECH_PASSWORD="<contraseña_tecnico_local>"
DEMO_CLIENT_EMAIL="<correo_cliente_local>"
DEMO_CLIENT_PASSWORD="<contraseña_cliente_local>"

# ==============================================
# 🧪 BYPASS DE AUTH (SOLO TESTING)
# ==============================================
# Nunca activar en producción.
# Modos:
# - header (recomendado): requiere header `x-test-bypass: 1`
# - always: ignora auth en todas las rutas protegidas por withAuth/withRoles
AUTH_BYPASS_FOR_TESTS="false"
AUTH_BYPASS_MODE="header"
AUTH_BYPASS_ROLE="admin"
AUTH_BYPASS_USER_ID="1"
AUTH_BYPASS_EMAIL="test.admin@somostecnicos.local"
AUTH_BYPASS_USERNAME="test_admin"
AUTH_BYPASS_NAME="Test Admin"
